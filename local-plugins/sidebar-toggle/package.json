{
  "name": "quartz-plugin-sidebar-toggle",
  "version": "1.0.0",
  "description": "Floating hamburger that toggles the left sidebar on narrow screens.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./components": { "types": "./dist/components/index.d.ts", "import": "./dist/components/index.js" }
  },
  "quartz": {
    "name": "sidebar-toggle",
    "displayName": "Sidebar Toggle",
    "category": "component",
    "version": "1.0.0",
    "defaultEnabled": true,
    "components": {
      "SidebarToggle": {
        "displayName": "Sidebar Toggle",
        "defaultPosition": "beforeBody",
        "defaultPriority": 1
      }
    }
  }
}
